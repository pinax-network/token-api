# Database Configuration (optional, defaults to dbs-config.yaml)
# Path to the YAML configuration file containing database and network settings
DBS_CONFIG_PATH=dbs-config.yaml

# API Server (optional)
PORT=8000
HOSTNAME=localhost
IDLE_TIMEOUT=60
MAX_LIMIT=1000

# OpenAPI (optional)
DISABLE_OPENAPI_SERVERS=false

# HTTP Cache-Control (optional)
# CACHE_DISABLE=false                  # Set to true to omit Cache-Control headers entirely
# CACHE_SERVER_MAX_AGE=600             # s-maxage for shared/proxy caches (Caddy, Envoy) in seconds
# CACHE_MAX_AGE=60                     # max-age for browser caches in seconds
# CACHE_STALE_WHILE_REVALIDATE=30      # stale-while-revalidate window in seconds (RFC 5861)

# Logging (optional)
PRETTY_LOGGING=true
VERBOSE=true
