# Database Configuration (optional, defaults to dbs-config.yaml)
# Path to the YAML configuration file containing database and network settings
DBS_CONFIG_PATH=dbs-config.yaml

# API Server (optional)
PORT=8000
HOSTNAME=localhost
IDLE_TIMEOUT=60
MAX_LIMIT=1000

# OpenAPI (optional)
DISABLE_OPENAPI_SERVERS=false

# Caching (optional)
# CACHE_DURATIONS=10,600     # Comma-separated TTLs in seconds: default,long (used for s-maxage)
# DISABLE_CACHE=false        # Set to true to omit Cache-Control headers entirely

# Logging (optional)
PRETTY_LOGGING=true
VERBOSE=true
