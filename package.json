{
    "private": true,
    "name": "token-api",
    "description": "Token API",
    "version": "3.14.1",
    "homepage": "https://github.com/pinax-network/token-api",
    "license": "Apache-2.0",
    "type": "module",
    "authors": [
        {
            "name": "Etienne Donneger",
            "email": "etienne@pinax.network",
            "url": "https://github.com/0237h"
        },
        {
            "name": "Denis Carriere",
            "email": "denis@pinax.network",
            "url": "https://github.com/DenisCarriere/"
        },
        {
            "name": "Mathieu Lefebvre",
            "email": "mathieu@pinax.network",
            "url": "https://github.com/Matlefebvre1234/"
        },
        {
            "name": "Yaro Shkvorets",
            "email": "yaro@pinax.network",
            "url": "https://github.com/YaroShkvorets/"
        }
    ],
    "scripts": {
        "dev": "bun --watch index.ts",
        "start": "bun index.ts",
        "build": "bun build --compile index.ts --outfile token-api",
        "test": "bun test --coverage",
        "test:db": "DB_TESTS=true bun test --timeout 30000 --coverage",
        "test:db:sql": "DB_TESTS=true bun test src/routes/sql.spec.ts --timeout 30000",
        "test:db:perf": "DB_TESTS=true bun test src/routes/perf.spec.ts --timeout 30000",
        "test:db:health": "DB_TESTS=true bun test src/routes/sql.spec.ts --timeout 30000 -t 'health|networks'",
        "test:db:nft": "DB_TESTS=true bun test --timeout 30000 -t 'nft'",
        "test:db:evm": "DB_TESTS=true bun test --timeout 30000 -t 'evm'",
        "test:db:svm": "DB_TESTS=true bun test --timeout 30000 -t 'svm'",
        "test:db:tvm": "DB_TESTS=true bun test --timeout 30000 -t 'tvm'",
        "test:stable": "bun scripts/test-stablecoins.ts",
        "perf": "bun run scripts/perf.ts",
        "query-log": "bun run scripts/query-log.ts",
        "clean": "bun i --force",
        "typecheck": "tsc --noEmit",
        "fix": "biome check --write --unsafe",
        "lint": "bun run typecheck && biome check ."
    },
    "dependencies": {
        "@clickhouse/client": "^1.12.0",
        "@clickhouse/client-web": "^1.12.0",
        "@hono/zod-validator": "^0.7.5",
        "@pinax/graph-networks-registry": "^0.7.1",
        "@web3icons/core": "^4.0.18",
        "commander": "^14.0.0",
        "dotenv": "^17.2.1",
        "hono": "^4.8.12",
        "hono-openapi": "^1.0.0",
        "tslog": "^4.9.3",
        "yaml": "^2.8.2",
        "zod": "^4.0.15"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.1.4",
        "@types/bun": "^1.2.19",
        "typescript": "^5.9.2"
    }
}
