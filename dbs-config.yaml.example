# Token API Database Configuration
# This file defines the database mappings for each network and data type.
# Set DBS_CONFIG_PATH environment variable to point to this file.
#
# Each network entry has `type` and `cluster` (required), plus any number of
# database keys. Each key `foo` maps to `fooDatabases` in the parsed config.
clusters:
  a:
    url: http://127.0.0.1:8123
    username: default
    password: ""
  b:
    url: http://127.0.0.1:8124
    username: default
    password: ""

networks:
  # EVM Networks
  mainnet:
    type: evm
    cluster: b
    transfers: mainnet:evm-transfers@v0.2.2
    balances: mainnet:evm-balances@v0.2.3
    nfts: mainnet:evm-nft-tokens@v0.6.2
    dexes: mainnet:evm-dex@v0.2.6
    contracts: mainnet:evm-contracts@v0.3.0

  # SVM Networks
  solana:
    type: svm
    cluster: a
    transfers: solana:svm-transfers@v0.3.1
    balances: solana:svm-balances@v0.3.2
    accounts: solana:svm-accounts@v0.3.0
    metadata: solana:svm-metadata@v0.3.1
    dexes: solana:svm-dex@v0.4.0

  # TVM Networks
  tron:
    type: tvm
    cluster: b
    transfers: tron:evm-transfers@v0.2.3
    dexes: tron:evm-dex@v0.2.6

  # Polymarket
  polymarket:
    type: polymarket
    cluster: b
    polymarket: polygon:evm-polymarket@v0.1.2
    scraper: polymarket
